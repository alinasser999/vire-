{%- liquid
  assign rendered_cards = 0
  assign panel_category = category | default: 'all'
-%}

{%- for block in blocks -%}
  {%- if block.type == 'home_demo_product' -%}
    {%- liquid
      assign product_category = block.settings.demo_category | default: 'all'
      assign should_render = false

      if panel_category == 'all'
        assign should_render = true
      elsif product_category == panel_category or product_category == 'all'
        assign should_render = true
      endif
    -%}

    {%- if should_render -%}
      {%- liquid
        assign rendered_cards = rendered_cards | plus: 1
        assign default_demo_link = routes.root_url | append: '#vire-products'
        assign demo_link = block.settings.demo_link | default: default_demo_link
        assign demo_title = block.settings.demo_title | default: 'Demo product'
      -%}
      <div class="product-card reveal" data-product-card {{ block.shopify_attributes }}>
        <div class="product-img-wrap">
          {%- if block.settings.demo_image != blank -%}
            {{
              block.settings.demo_image
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                widths: '360, 533, 720, 900',
                sizes: '(min-width: 990px) 25vw, 50vw',
                alt: demo_title
            }}
          {%- elsif block.settings.demo_image_url != blank -%}
            <img
              src="{{ block.settings.demo_image_url }}"
              alt="{{ demo_title | escape }}"
              width="900"
              height="1200"
              loading="lazy"
            >
          {%- else -%}
            <div class="product-img-placeholder">
              {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
          {%- if block.settings.demo_sold_out -%}
            <div class="product-badge sold">Sold out</div>
          {%- elsif block.settings.demo_badge != blank -%}
            <div class="product-badge">{{ block.settings.demo_badge }}</div>
          {%- endif -%}
          <a href="{{ demo_link }}" class="product-quick-add">View Product</a>
        </div>
        <div class="product-info">
          <div class="product-name">{{ demo_title }}</div>
          {%- if block.settings.demo_price != blank -%}
            <div class="product-price">{{ block.settings.demo_price }}</div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- if rendered_cards == 0 -%}
  <div class="products-empty reveal">{{ empty_message }}</div>
{%- endif -%}
