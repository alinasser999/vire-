{% comment %}
  ============================================
  VIRE STUDIOS — vire-homepage.liquid
  احفظ الملف ده في: Sections > vire-homepage.liquid
  ============================================
{% endcomment %}

{{ 'vire-custom.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign all_collection = collections['all']
  assign selected_home_collection = collections[section.settings.home_primary_collection]
  assign selected_tops_collection = collections[section.settings.tops_collection]
  assign selected_bottoms_collection = collections[section.settings.bottoms_collection]
  assign selected_blanks_collection = collections[section.settings.blanks_collection]
  assign products_url = routes.root_url | append: '#vire-products'
  assign shop_all_url = products_url
  assign tops_collection = collections['tops']
  assign bottoms_collection = collections['bottoms']
  assign blanks_collection = collections['blanks']
  assign tops_url = products_url
  assign bottoms_url = products_url
  assign blanks_url = routes.root_url | append: '#vire-blanks'

  if selected_home_collection != blank
    assign all_collection = selected_home_collection
    assign shop_all_url = selected_home_collection.url
  endif

  if selected_tops_collection != blank
    assign tops_collection = selected_tops_collection
  endif

  if selected_bottoms_collection != blank
    assign bottoms_collection = selected_bottoms_collection
  endif

  if selected_blanks_collection != blank
    assign blanks_collection = selected_blanks_collection
  endif

  if tops_collection != blank
    assign tops_url = tops_collection.url
  endif

  if bottoms_collection != blank
    assign bottoms_url = bottoms_collection.url
  endif

  if blanks_collection != blank
    assign blanks_url = blanks_collection.url
  endif

  assign about_url = routes.root_url | append: '#vire-about'
  assign lookbook_url = routes.root_url | append: '#vire-lookbook'
  assign shipping_url = routes.root_url | append: '#vire-shipping'
  assign size_url = routes.root_url | append: '#vire-size-guide'
  assign contact_url = routes.root_url | append: '#vire-contact'
  assign hero_primary_url = section.settings.hero_btn1_link | default: products_url
  assign hero_secondary_url = section.settings.hero_btn2_link | default: lookbook_url
  assign countdown_url = section.settings.countdown_link | default: products_url
  assign privacy_url = shop.privacy_policy.url | default: routes.root_url
  assign terms_url = shop.terms_of_service.url | default: routes.root_url
  assign refund_url = shop.refund_policy.url | default: routes.root_url
-%}

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- Mobile menu -->
<div class="mobile-menu" id="mobileMenu">
  <button class="mobile-close" id="mobileClose">✕ Close</button>
  <a href="{{ shop_all_url }}">Shop All</a>
  <a href="{{ tops_url }}">Tops</a>
  <a href="{{ bottoms_url }}">Bottoms</a>
  <a href="{{ blanks_url }}">Blanks</a>
  <a href="{{ lookbook_url }}">Lookbook</a>
</div>

<!-- Announcement Bar -->
<div class="vire-announcement">
  <div class="announcement-track">
    <span>{{ section.settings.announcement_text_1 }}</span>
    <span>{{ section.settings.announcement_text_2 }}</span>
    <span>{{ section.settings.announcement_text_3 }}</span>
    <span>{{ section.settings.announcement_text_1 }}</span>
    <span>{{ section.settings.announcement_text_2 }}</span>
    <span>{{ section.settings.announcement_text_3 }}</span>
  </div>
</div>

<!-- Nav -->
<nav class="vire-nav" id="navbar">
  <div class="nav-left">
    <ul class="nav-links-left">
      <li><a href="{{ shop_all_url }}">+ Shop All</a></li>
      <li><a href="{{ tops_url }}">Tops</a></li>
      <li><a href="{{ bottoms_url }}">Bottoms</a></li>
      <li><a href="{{ blanks_url }}">Blanks</a></li>
      <li><a href="{{ lookbook_url }}">Lookbook</a></li>
      <li><a href="{{ contact_url }}">Contact</a></li>
    </ul>
  </div>
  <a href="{{ routes.root_url }}" class="nav-logo">VIRE</a>
  <div class="nav-right">
    <span class="nav-locale">Egypt (EGP ج.م) ▾</span>
    <a href="{{ routes.account_url }}" class="nav-icon" style="display:flex">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    </a>
    <div style="display:flex;align-items:center;gap:0">
      <a href="{{ routes.cart_url }}" class="nav-icon" style="display:flex">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      </a>
      <span class="cart-badge">{{ cart.item_count }}</span>
    </div>
    <div class="hamburger" id="hamburger"><span></span><span></span></div>
  </div>
</nav>

<!-- ===== HERO ===== -->
<section class="hero" id="heroSection" {% if section.settings.hero_image != blank %}style="background-image: url('{{ section.settings.hero_image | image_url: width: 1920 }}'); background-size: cover; background-position: center;"{% endif %}>
  <div class="hero-bg-layer" id="heroBgLayer"></div>
  <div class="hero-img-layer" id="heroImgLayer"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <span class="hero-eyebrow">{{ section.settings.hero_eyebrow }}</span>
 {% if section.settings.hero_logo != blank %}
  <img src="{{ section.settings.hero_logo | image_url: width: 500 }}" 
       alt="VIRE" 
       class="hero-logo-img"
       width="500" height="400">
{% endif %}
    <p class="hero-sub">{{ section.settings.hero_subtitle }}</p>
    <div class="hero-ctas">
      <a href="{{ hero_primary_url }}" class="btn-ink">{{ section.settings.hero_btn1_text }}</a>
      <a href="{{ hero_secondary_url }}" class="btn-outline">{{ section.settings.hero_btn2_text }}</a>
    </div>
  </div>
  <div class="hero-scroll">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- Countdown -->
<div class="countdown-bar">
  <span class="cd-label">{{ section.settings.countdown_label }}</span>
  <div class="cd-units">
    <div class="cd-unit"><span class="cd-num" id="cd-days">00</span><span class="cd-unit-label">D</span></div>
    <span class="cd-sep">:</span>
    <div class="cd-unit"><span class="cd-num" id="cd-hours">00</span><span class="cd-unit-label">H</span></div>
    <span class="cd-sep">:</span>
    <div class="cd-unit"><span class="cd-num" id="cd-mins">00</span><span class="cd-unit-label">M</span></div>
    <span class="cd-sep">:</span>
    <div class="cd-unit"><span class="cd-num" id="cd-secs">00</span><span class="cd-unit-label">S</span></div>
  </div>
  <a href="{{ countdown_url }}" class="cd-cta">{{ section.settings.countdown_cta }}</a>
</div>

<!-- Statement -->
<div class="statement reveal" id="vire-about">
  <div>
    <span class="statement-big">FORMS,</span>
    <span class="statement-big outline">NOT</span>
    <span class="statement-big">BASICS.</span>
    <p class="statement-body">We build garments with intention — every seam placed, every silhouette considered. This isn't just clothing, it's a statement of direction.</p>
    <div style="margin-top:36px"><a href="{{ lookbook_url }}" class="btn-ink">Explore the Brand</a></div>
  </div>
  <div class="statement-img-wrap">
    {% if section.settings.statement_image != blank %}
      <img src="{{ section.settings.statement_image | image_url: height: 1000, width: 800 }}" alt="Brand" width="800" height="1000">
    {% else %}
      <img src="https://images.unsplash.com/photo-1583744946564-b52ac1c389c8?w=800&q=80" alt="Brand" width="800" height="1000">
    {% endif %}
    <div class="statement-img-overlay"></div>
  </div>
</div>

<!-- Collections -->
<section class="collections">
  <div class="section-eyebrow reveal">Vire Collections</div>
  <h2 class="section-title reveal">SHOP BY<br>CATEGORY</h2>
  <div class="collections-grid">
    <a href="{{ bottoms_url }}" class="collection-card reveal">
      {%- if bottoms_collection != blank and bottoms_collection.image != blank -%}
        <img
          src="{{ bottoms_collection.image | image_url: width: 800 }}"
          alt="{{ bottoms_collection.title | escape }}"
          width="800"
          height="1000"
          loading="lazy"
        >
      {%- elsif bottoms_collection != blank and bottoms_collection.products.first.featured_media != blank -%}
        <img
          src="{{ bottoms_collection.products.first.featured_media | image_url: width: 800 }}"
          alt="{{ bottoms_collection.title | escape }}"
          width="800"
          height="1000"
          loading="lazy"
        >
      {%- else -%}
        <img src="https://images.unsplash.com/photo-1542272604-787c3835535d?w=800&q=70" alt="Bottoms" width="800" height="1000" loading="lazy">
      {%- endif -%}
      <div class="collection-info"><div class="collection-name">BOTTOMS</div><div class="collection-link">Shop now</div></div>
    </a>
    <a href="{{ tops_url }}" class="collection-card reveal reveal-delay-1">
      {%- if tops_collection != blank and tops_collection.image != blank -%}
        <img
          src="{{ tops_collection.image | image_url: width: 800 }}"
          alt="{{ tops_collection.title | escape }}"
          width="800"
          height="1000"
          loading="lazy"
        >
      {%- elsif tops_collection != blank and tops_collection.products.first.featured_media != blank -%}
        <img
          src="{{ tops_collection.products.first.featured_media | image_url: width: 800 }}"
          alt="{{ tops_collection.title | escape }}"
          width="800"
          height="1000"
          loading="lazy"
        >
      {%- else -%}
        <img src="https://images.unsplash.com/photo-1523381210434-271e8be1f52b?w=800&q=70" alt="Tops" width="800" height="1000" loading="lazy">
      {%- endif -%}
      <div class="collection-info"><div class="collection-name">TOPS</div><div class="collection-link">Shop now</div></div>
    </a>
  </div>
</section>

<!-- Products -->
<section class="products" id="vire-products">
  <div class="products-header">
    <div>
      <div class="section-eyebrow reveal">All Products</div>
      <h2 class="section-title reveal" style="margin-bottom:0">ALL ITEMS</h2>
    </div>
    <div class="products-filters reveal">
      <button class="filter-btn active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="tops">Tops</button>
      <button class="filter-btn" data-filter="bottoms">Bottoms</button>
    </div>
  </div>
  <div class="products-grid" data-products-panel="all">
    {%- if all_collection != blank and all_collection.products_count > 0 -%}
      {%- for product in all_collection.products limit: section.settings.home_products_limit -%}
        <a href="{{ product.url }}" class="product-card reveal" data-product-card>
          <div class="product-img-wrap">
            {%- if product.featured_media != blank -%}
              <img
                src="{{ product.featured_media | image_url: width: 900 }}"
                alt="{{ product.featured_media.alt | escape | default: product.title | escape }}"
                width="900"
                height="1125"
                loading="lazy"
              >
            {%- endif -%}
            {%- if product.available == false -%}
              <div class="product-badge sold">Sold out</div>
            {%- elsif product.compare_at_price > product.price -%}
              <div class="product-badge">Sale</div>
            {%- endif -%}
            <div class="product-quick-add">View Product</div>
          </div>
          <div class="product-info">
            <div class="product-name">{{ product.title }}</div>
            <div class="product-price">{{ product.price | money }}</div>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- render 'vire-homepage-demo-products',
        blocks: section.blocks,
        category: 'all',
        empty_message: 'Add demo product blocks in this Home page section, or add products in Shopify.'
      -%}
    {%- endif -%}
  </div>
  <div class="products-grid" data-products-panel="tops" hidden>
    {%- if tops_collection != blank and tops_collection.products_count > 0 -%}
      {%- for product in tops_collection.products limit: section.settings.home_products_limit -%}
        <a href="{{ product.url }}" class="product-card reveal" data-product-card>
          <div class="product-img-wrap">
            {%- if product.featured_media != blank -%}
              <img
                src="{{ product.featured_media | image_url: width: 900 }}"
                alt="{{ product.featured_media.alt | escape | default: product.title | escape }}"
                width="900"
                height="1125"
                loading="lazy"
              >
            {%- endif -%}
            {%- if product.available == false -%}
              <div class="product-badge sold">Sold out</div>
            {%- elsif product.compare_at_price > product.price -%}
              <div class="product-badge">Sale</div>
            {%- endif -%}
            <div class="product-quick-add">View Product</div>
          </div>
          <div class="product-info">
            <div class="product-name">{{ product.title }}</div>
            <div class="product-price">{{ product.price | money }}</div>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- render 'vire-homepage-demo-products',
        blocks: section.blocks,
        category: 'tops',
        empty_message: 'Add a demo product block and set its category to Tops.'
      -%}
    {%- endif -%}
  </div>
  <div class="products-grid" data-products-panel="bottoms" hidden>
    {%- if bottoms_collection != blank and bottoms_collection.products_count > 0 -%}
      {%- for product in bottoms_collection.products limit: section.settings.home_products_limit -%}
        <a href="{{ product.url }}" class="product-card reveal" data-product-card>
          <div class="product-img-wrap">
            {%- if product.featured_media != blank -%}
              <img
                src="{{ product.featured_media | image_url: width: 900 }}"
                alt="{{ product.featured_media.alt | escape | default: product.title | escape }}"
                width="900"
                height="1125"
                loading="lazy"
              >
            {%- endif -%}
            {%- if product.available == false -%}
              <div class="product-badge sold">Sold out</div>
            {%- elsif product.compare_at_price > product.price -%}
              <div class="product-badge">Sale</div>
            {%- endif -%}
            <div class="product-quick-add">View Product</div>
          </div>
          <div class="product-info">
            <div class="product-name">{{ product.title }}</div>
            <div class="product-price">{{ product.price | money }}</div>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- render 'vire-homepage-demo-products',
        blocks: section.blocks,
        category: 'bottoms',
        empty_message: 'Add a demo product block and set its category to Bottoms.'
      -%}
    {%- endif -%}
  </div>
</section>

<!-- Split Blanks -->
<div class="split-feature" id="vire-blanks">
  <div class="split-img">
    {% if section.settings.blanks_image != blank %}
      <img src="{{ section.settings.blanks_image | image_url: width: 1000 }}" alt="Blanks" width="1000" height="1250">
    {% else %}
      <img src="https://images.unsplash.com/photo-1620799140408-edc6dcb6d633?w=1000&q=80" alt="Blanks" width="1000" height="1250">
    {% endif %}
  </div>
  <div class="split-content">
    <div class="split-tag">Sister Brand</div>
    <h2 class="split-title">VIRE<br>BLANKS</h2>
    <p class="split-body">Premium heavyweight basics. No graphics, no gimmicks — just exceptional fabric and precise construction. The foundation of every great outfit.</p>
    <a href="{{ blanks_url }}" class="btn-ink">Shop Blanks</a>
  </div>
</div>

<!-- Testimonials -->
<section class="testimonials">
  <div class="testimonials-header">
    <div>
      <div class="section-eyebrow">Customers</div>
      <h2 class="section-title" style="margin-bottom:0">TESTIMONIALS</h2>
    </div>
    <span style="font-family:var(--font-cond);font-size:12px;letter-spacing:4px;color:var(--ink3);text-transform:uppercase">100,000+ Customers</span>
  </div>
  <div class="testimonials-track-wrap">
    <div class="testimonials-track" id="testimonialTrack"></div>
  </div>
</section>

<!-- Lookbook -->
<section class="lookbook" id="vire-lookbook">
  <div class="section-eyebrow reveal">How they wear it</div>
  <h2 class="section-title reveal">LOOKBOOK</h2>
  <div class="lookbook-grid">
    <a href="{{ shop_all_url }}" class="look-item"><img src="https://images.unsplash.com/photo-1509631179647-0177331693ae?w=1000&q=70" alt="Look 1" width="1000" height="1250"><div class="look-overlay"><div class="look-tag">Washed Neutrals</div><div class="look-name">Lookbook 01</div></div></a>
    <a href="{{ tops_url }}" class="look-item"><img src="https://images.unsplash.com/photo-1551537482-f2075a1d41f2?w=800&q=70" alt="Look 2" width="800" height="1000"><div class="look-overlay"><div class="look-tag">Top Layer</div><div class="look-name">Lookbook 02</div></div></a>
    <a href="{{ bottoms_url }}" class="look-item"><img src="https://images.unsplash.com/photo-1490481651871-ab68de25d43d?w=800&q=70" alt="Look 3" width="800" height="1000"><div class="look-overlay"><div class="look-tag">Everyday Uniform</div><div class="look-name">Lookbook 03</div></div></a>
    <a href="{{ blanks_url }}" class="look-item"><img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&q=70" alt="Look 4" width="800" height="1000"><div class="look-overlay"><div class="look-tag">Blank Base</div><div class="look-name">Lookbook 04</div></div></a>
  </div>
</section>

<!-- Info Pages -->
<section class="vire-info-pages" id="vire-help">
  <div class="section-eyebrow reveal">Store guide</div>
  <h2 class="section-title reveal">FIT, CARE<br>DELIVERY</h2>
  <div class="vire-info-grid">
    <article class="vire-info-panel reveal" id="vire-size-guide">
      <span class="vire-info-count">01</span>
      <h3>Size guide</h3>
      <p>Relaxed streetwear fits. Check each product description for exact measurements before ordering.</p>
      <a href="{{ shop_all_url }}">Shop all</a>
    </article>
    <article class="vire-info-panel reveal reveal-delay-1" id="vire-shipping">
      <span class="vire-info-count">02</span>
      <h3>Shipping</h3>
      <p>Orders dispatch in 1-3 business days. Delivery timing depends on your destination and checkout method.</p>
      <a href="{{ shop_all_url }}">Start order</a>
    </article>
    <article class="vire-info-panel reveal reveal-delay-2" id="vire-support">
      <span class="vire-info-count">03</span>
      <h3>Support</h3>
      <p>Need help with sizing, delivery, or an exchange? Message the store before checkout and we will guide you.</p>
      <a href="mailto:hello@virestudios.com">Contact us</a>
    </article>
  </div>
</section>

<!-- Instagram -->
<section class="instagram">
  <div class="instagram-header">
    <span class="instagram-handle">@VIRESTUDIOS</span>
    <span class="instagram-sub">Follow us on Instagram — 100k+ Followers</span>
  </div>
  <div class="instagram-grid" id="igGrid"></div>
  <div class="instagram-follow"><a href="https://instagram.com/virestudios" class="btn-ink">Follow Us</a></div>
</section>

<!-- Newsletter -->
<section class="newsletter" id="vire-contact">
  <h2 class="newsletter-title reveal">GET EARLY ACCESS</h2>
  <p class="newsletter-sub reveal">Sign up for drops, offers, and exclusive content</p>
  {% form 'customer' %}
    <input type="hidden" name="contact[tags]" value="newsletter">
    <div class="newsletter-form reveal">
      <input type="email" name="contact[email]" class="newsletter-input" placeholder="YOUR@EMAIL.COM" required>
      <button type="submit" class="newsletter-submit">Subscribe</button>
    </div>
  {% endform %}
</section>

<!-- Footer -->
<footer class="vire-footer">
  <div>
    <a href="{{ routes.root_url }}" class="footer-logo">VIRE</a>
    <p class="footer-tagline">Real Intent.<br>Real Direction.<br>Real Presence.</p>
    <div class="footer-socials">
      <a href="https://instagram.com/virestudios" class="social-link">IG</a>
      <a href="https://tiktok.com/@virestudios" class="social-link">TK</a>
      <a href="https://facebook.com/virestudios" class="social-link">FB</a>
    </div>
  </div>
  <div>
    <p class="footer-col-title">Shop</p>
    <ul class="footer-links">
      <li><a href="{{ shop_all_url }}">Shop All</a></li>
      <li><a href="{{ tops_url }}">Tops</a></li>
      <li><a href="{{ bottoms_url }}">Bottoms</a></li>
      <li><a href="{{ blanks_url }}">Blanks</a></li>
    </ul>
  </div>
  <div>
    <p class="footer-col-title">Help</p>
    <ul class="footer-links">
      <li><a href="{{ shipping_url }}">Shipping Info</a></li>
      <li><a href="{{ size_url }}">Size Guide</a></li>
      <li><a href="{{ contact_url }}">Contact Us</a></li>
      <li><a href="{{ shop_all_url }}">Refund & Exchange</a></li>
    </ul>
  </div>
  <div>
    <p class="footer-col-title">Brand</p>
    <ul class="footer-links">
      <li><a href="{{ about_url }}">About Us</a></li>
      <li><a href="{{ lookbook_url }}">Lookbook</a></li>
      <li><a href="{{ blanks_url }}">Blanks</a></li>
      <li><a href="https://instagram.com/virestudios">Instagram</a></li>
    </ul>
  </div>
</footer>
<div class="vire-footer-bottom">
  <span class="footer-copy">© {{ 'now' | date: '%Y' }} Vire Studios. All rights reserved.</span>
  <div class="footer-legal">
    <a href="{{ privacy_url }}">Privacy Policy</a>
    <a href="{{ terms_url }}">Terms of Service</a>
    <a href="{{ refund_url }}">Refund Policy</a>
  </div>
</div>

<script src="{{ 'vire-custom.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Vire Homepage",
  "settings": [
    {
      "type": "header",
      "content": "Announcement Bar"
    },
    {
      "type": "text",
      "id": "announcement_text_1",
      "label": "Announcement 1",
      "default": "FREE SHIPPING ON ORDERS OVER LE 1,500 — SUMMER DROP LIVE NOW"
    },
    {
      "type": "text",
      "id": "announcement_text_2",
      "label": "Announcement 2",
      "default": "NEW ARRIVALS WEEKLY — FOLLOW @VIRE"
    },
    {
      "type": "text",
      "id": "announcement_text_3",
      "label": "Announcement 3",
      "default": "REAL INTENT. REAL DIRECTION. REAL PRESENCE."
    },
    {
      "type": "header",
      "content": "Hero Section"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    },
    {
  "type": "image_picker",
  "id": "hero_logo",
  "label": "Hero Logo Image"
},
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Hero Eyebrow Text",
      "default": "Summer Drop — Now Live"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero Title",
      "default": "VIRE"
    },
    {
